class Solution {
    public int minMirrorPairDistance(int[] nums) {
      

        int ans = 999999;
        Map<Integer, Integer> map = new HashMap<>();

        for (int i = 0; i < nums.length; i++) {
            int n = nums[i];
            if (map.containsKey(n))
                ans = Math.min(ans, i - map.get(n));
            int nn = 0;
            while (n > 0) {
                int t = n % 10;
                n /= 10;
                nn *= 10;
                nn += t;
            } 
            map.put(nn, i);
        }
        if (ans == 999999)
            return -1;
        return ans;
    }
}
