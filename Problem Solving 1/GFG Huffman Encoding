class Node {
    char ch;
    int freq;
    int index; // original position in input string
    Node left, right;

    // Leaf node
    Node(char ch, int freq, int index) {
        this.ch = ch;
        this.freq = freq;
        this.index = index;
    }

    // Internal node
    Node(int freq, Node left, Node right, int index) {
        this.ch = '\0'; // internal node
        this.freq = freq;
        this.left = left;
        this.right = right;
        this.index = index; // propagate smallest index among children
    }
}

class Solution {
    public ArrayList<String> huffmanCodes(String s, int f[]) {
        int n = s.length();

        // Special case: only one character
        if (n == 1) {
            ArrayList<String> codes = new ArrayList<>();
            codes.add("0");
            return codes;
        }

        // Priority queue with tie-breaking on index
        PriorityQueue<Node> pq = new PriorityQueue<>(
            (a, b) -> a.freq == b.freq ? a.index - b.index : a.freq - b.freq
        );

        // Step 1: create leaf nodes
        for (int i = 0; i < n; i++) {
            pq.add(new Node(s.charAt(i), f[i], i));
        }

        // Step 2: build Huffman tree
        while (pq.size() > 1) {
            Node left = pq.poll();
            Node right = pq.poll();
            // propagate smallest index among children
            Node parent = new Node(left.freq + right.freq, left, right, Math.min(left.index, right.index));
            pq.add(parent);
        }

        Node root = pq.poll();
        ArrayList<String> codes = new ArrayList<>();
        preorder(root, "", codes);
        return codes;
    }
    
    private void preorder(Node node, String code, ArrayList<String> codes) {
        if (node == null) return;
        if (node.ch != '\0') { // leaf node
            codes.add(code);
        }
        preorder(node.left, code + "0", codes);
        preorder(node.right, code + "1", codes);
    }
}
