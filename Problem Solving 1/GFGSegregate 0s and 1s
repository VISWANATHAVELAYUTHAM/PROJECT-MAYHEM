class Solution {
    void segregate0and1(int[] arr) {
        int zeroCount = 0;

        for (int x : arr)
            if (x == 0) zeroCount++;

        for (int i = 0; i < arr.length; i++) {
            if (i < zeroCount)
                arr[i] = 0;
            else
                arr[i] = 1;
        }
    }
}

